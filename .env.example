# Copy this file to `.env` and fill in real values before `docker compose up`.
# `.env` is git-ignored — never commit real secrets.

POSTGRES_USER=planner
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=planning
# Must be at least 48 random chars. Generate one with:  openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret-string-at-least-48-chars-long

# ---------------------------------------------------------------------------
# Single sign-on (OIDC) — OPTIONAL.
# You can also configure SSO from the admin UI (Administration → SSO / OIDC),
# which stores the settings in the database. Setting the three vars below
# instead makes the env config AUTHORITATIVE and the admin UI read-only.
# Leave everything unset to keep username/password login only. Works with any
# OpenID Connect provider (Keycloak, Authentik, Google, Entra ID, Okta,
# GitLab…). The redirect/callback URL to register at your provider is:
#   https://<your-domain>/auth/oidc/callback
# ---------------------------------------------------------------------------
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
# Behind a reverse proxy, set BEHIND_PROXY=1 so the auto-detected callback uses
# the right https scheme/host. If it's still wrong, pin the exact public
# callback URL here (must match what's registered at the provider):
#OIDC_REDIRECT_URI=https://your-domain/auth/oidc/callback
# Optional tuning (defaults shown):
#OIDC_SCOPES=openid email profile
#OIDC_USERNAME_CLAIM=preferred_username
#OIDC_NAME_CLAIM=name
#OIDC_BUTTON_LABEL=Connexion SSO
# Auto-create local accounts for unknown SSO users (off by default — when off,
# a user must already exist with a matching username before they can sign in):
#OIDC_AUTO_CREATE=1
#OIDC_DEFAULT_ROLES=audit_web
